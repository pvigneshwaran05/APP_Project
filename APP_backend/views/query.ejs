<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Query - Green Energy Hub</title>
    <link rel="stylesheet" href="home-styles.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css"
    />
  </head>
  <body>
    <div class="top-bar">
      <div class="user-pill">
        <i class="fas fa-user"></i>
        <span><%= typeof name !== 'undefined' ? name : 'User' %></span>
      </div>
    </div>

    <nav class="sidebar" style="background-color: white">
      <div class="logo">
        <h1>Green Energy Hub</h1>
      </div>
      <ul class="nav-links">
        <li>
          <a href="/home"><i class="fas fa-home"></i><span>Home</span></a>
        </li>
        <li>
          <a href="/games"><i class="fas fa-gamepad"></i><span>Games</span></a>
        </li>
        <li>
          <a href="/events"
            ><i class="fas fa-calendar-alt"></i><span>Events</span></a
          >
        </li>
        <li>
          <a href="#"
            ><i class="fas fa-info-circle"></i><span>About Us</span></a
          >
        </li>
        <li>
          <a href="#contacts"
            ><i class="fas fa-envelope"></i><span>Contact</span></a
          >
        </li>
        <li>
          <a href="/query"
            ><i class="fas fa-question-circle"></i><span>Queries</span></a
          >
        </li>
      </ul>
    </nav>

    <main class="main-content">
      <section class="hero">
        <h2>User Problems</h2>
        <p>
          Have a question or need assistance? We're here to help! Submit your
          query below, and we'll get back to you with a solution as soon as
          possible.
        </p>
      </section>

      <section class="query-section" style="font-size: xx-large">
        <div class="query-card">
          <div class="query-icon">
            <i class="fas fa-question-circle"></i>
          </div>
          <h3>Post a Problem</h3>
          <form id="query-form">
            <label for="query">Enter Your Query:</label>
            <input
              type="text"
              id="query"
              placeholder="Type Something..."
              name="query_box"
              style="padding: 10px; padding-right: 1000px"
            />
            <button type="submit" onclick="done()" style="background-color: #2ecc71;padding: 10px;color: white;"><strong>Submit</strong></button>
          </form>
        </div>
      </section>
      <br>
      <div class="response-banner" style="font-size: large">
        <h3>We're On It!</h3>
        <p>
          We will be returning back with the solution as soon as possible. Thank
          you for your patience!
        </p>
      </div>
    </main>

    <footer id="contacts">
      <p>&copy; 2024 Green Energy Hub | Contact: (807) 256-6972</p>
    </footer>

    <script>
      function done() {
        var txt = document.getElementById("query").value;
        if (txt != "") {
          alert("Query posted successfully...");
        }
      }
    </script>
  </body>
</html>
